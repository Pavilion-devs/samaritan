{
  "name": "samaritan",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dash:dev": "vite --config apps/dashboard/vite.config.ts",
    "dash:typecheck": "tsc -p apps/dashboard/tsconfig.json --noEmit",
    "dash:build": "pnpm dash:typecheck && pnpm dash:verify-edge && vite build --config apps/dashboard/vite.config.ts && vite build --config apps/dashboard/vite.worker.config.ts && pnpm dash:verify-build",
    "dash:serve": "tsx src/dash/server.ts",
    "dash:export-public": "tsx src/dash/export-public-bundle.ts && tsx src/dash/export-edge-bundle.ts",
    "dash:verify-edge": "tsx src/dash/verify-edge-bundle.ts",
    "dash:verify-build": "tsx src/dash/verify-sites-build.ts",
    "public:audit": "tsx src/public/audit-public-artifacts.ts --bundle public/artifacts/dashboard --bundle public/artifacts/edge",
    "security:audit": "pnpm audit --prod --audit-level moderate",
    "demo": "tsx src/demo/run-synthetic-judge-case.ts",
    "judge:check": "pnpm check && pnpm demo && pnpm receipt:verify -- public/artifacts/dashboard/synthetic-decision-receipt.json && pnpm public:audit && pnpm dash:build",
    "judge": "pnpm judge:check && pnpm dash:serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm dash:typecheck && pnpm test",
    "smoke:replay": "tsx src/replay/smoke.ts",
    "smoke:live": "tsx src/replay/live-smoke.ts",
    "smoke:discovery": "tsx src/replay/discovery-smoke.ts",
    "smoke:claude": "tsx src/agents/haiku-smoke.ts",
    "smoke:claude:analyst": "tsx src/agents/opus-smoke.ts",
    "import:mappings": "tsx src/import/build-mapping-registry.ts",
    "import:archives": "tsx src/import/import-archives.ts",
    "import:txline-metadata": "tsx src/import/backfill-txline-metadata.ts",
    "research:total-evidence": "tsx src/research/build-total-line-evidence.ts",
    "research:paired-live": "tsx src/research/analyze-paired-capture.ts",
    "research:historical-gate": "tsx src/research/run-historical-gate.ts",
    "paper:fixture-universe": "tsx src/harness/build-paper-fixture-universe.ts",
    "paper:init-ledgers": "tsx src/harness/initialize-paper-study-ledgers.ts",
    "paper:register-v2": "tsx src/harness/initialize-paper-study-ledgers.ts --register paper-study-v2-2026-07-18",
    "paper:claude-readiness": "tsx src/harness/verify-claude-paper-runtime.ts",
    "paper:run-captured": "tsx src/harness/run-captured-paper-session.ts",
    "paper:report": "tsx src/harness/write-paper-study-report.ts",
    "capture:readiness": "tsx src/harness/build-capture-readiness.ts",
    "capture:validate": "tsx src/harness/validate-capture-configs.ts",
    "capture:run-scheduled": "tsx src/harness/run-scheduled-capture.ts",
    "capture:analyze": "tsx src/harness/build-paired-capture-analysis.ts",
    "receipt:verify": "tsx src/proof/verify-decision-receipt.ts",
    "anchor:prepare": "tsx src/chain/prepare-decision-anchor.ts",
    "anchor:submit": "tsx src/chain/submit-decision-anchor.ts",
    "anchor:verify": "tsx src/chain/verify-decision-anchor.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@duckdb/node-api": "1.5.4-r.1",
    "@fontsource/ibm-plex-mono": "^5.2.6",
    "@fontsource/manrope": "^5.2.6",
    "@solana/web3.js": "^1.98.4",
    "better-sqlite3": "^12.11.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "stream-json": "^3.5.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.20.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/stream-json": "^1.7.8",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^4.1.10"
  }
}
